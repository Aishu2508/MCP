# Server Configuration
HOST=0.0.0.0
PORT=8000

# Database Configuration
DATABASE_URL=sqlite:///./gmail_mcp.db

# Fernet encryption key used to encrypt every user's stored Gmail app
# password at rest. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_a_generated_fernet_key

# How often (in seconds) the background worker polls every registered
# user's Gmail inbox for new mail via IMAP.
INBOX_POLL_INTERVAL_SECONDS=60

# Master switch for the background inbox poller.
ENABLE_BACKGROUND_POLLING=true

# NOTE: There is no single Gmail account configured here. Each user
# registers their own Gmail address + App Password at runtime via the
# add_gmail_account tool (or POST /accounts).
